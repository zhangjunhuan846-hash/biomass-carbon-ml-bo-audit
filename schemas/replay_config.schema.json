{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Offline BO replay config",
  "type": "object",
  "properties": {
    "target": {
      "type": "string"
    },
    "n_init": {
      "type": "integer",
      "minimum": 2
    },
    "budget": {
      "type": "integer",
      "minimum": 1
    },
    "seeds": {
      "type": "integer",
      "minimum": 1
    },
    "beta": {
      "type": "number"
    },
    "exclude_quality_tiers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "feature_columns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "target"
  ]
}