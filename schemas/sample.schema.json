{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Carbon literature sample record",
  "type": "object",
  "required": [
    "sample_id",
    "paper_id",
    "device_system"
  ],
  "properties": {
    "sample_id": {
      "type": "string"
    },
    "paper_id": {
      "type": "string"
    },
    "year": {
      "type": [
        "integer",
        "null"
      ]
    },
    "doi": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_location": {
      "type": [
        "string",
        "null"
      ]
    },
    "material_system": {
      "type": [
        "string",
        "null"
      ]
    },
    "device_system": {
      "type": "string",
      "enum": [
        "SIB",
        "LIB",
        "aqueous_SC",
        "unknown"
      ]
    },
    "precursor": {
      "type": [
        "string",
        "null"
      ]
    },
    "carbonization_temperature_c": {
      "type": [
        "number",
        "null"
      ]
    },
    "activation_method": {
      "type": [
        "string",
        "null"
      ]
    },
    "bet_m2_g": {
      "type": [
        "number",
        "null"
      ]
    },
    "total_pore_volume_cm3_g": {
      "type": [
        "number",
        "null"
      ]
    },
    "d002_nm": {
      "type": [
        "number",
        "null"
      ]
    },
    "id_ig": {
      "type": [
        "number",
        "null"
      ]
    },
    "n_at_percent": {
      "type": [
        "number",
        "null"
      ]
    },
    "o_at_percent": {
      "type": [
        "number",
        "null"
      ]
    },
    "electrolyte": {
      "type": [
        "string",
        "null"
      ]
    },
    "current_density_mag": {
      "type": [
        "number",
        "null"
      ]
    },
    "mass_loading_mg_cm2": {
      "type": [
        "number",
        "null"
      ]
    },
    "voltage_window": {
      "type": [
        "string",
        "null"
      ]
    },
    "ice_percent": {
      "type": [
        "number",
        "null"
      ]
    },
    "reversible_capacity_mah_g": {
      "type": [
        "number",
        "null"
      ]
    },
    "specific_capacitance_f_g": {
      "type": [
        "number",
        "null"
      ]
    },
    "quality_tier": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "Tier0",
        "Tier1",
        "Tier2",
        "Tier3",
        null
      ]
    },
    "needs_manual_check": {
      "type": [
        "string",
        "boolean",
        "null"
      ]
    },
    "check_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}